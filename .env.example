# Issuer Service Environment Configuration Template
#
# SECURITY WARNING: This file contains EXAMPLE values only.
# NEVER commit actual infrastructure IDs to version control.
# Copy this file to .env and replace with your actual values.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual Cloudflare IDs
#   # Deploy: wrangler deploy [--env production]
#
# See ENVIRONMENT_SETUP.md for detailed setup instructions.

#######################################################################
# Cloudflare Account & Zone Configuration
#######################################################################

# Your Cloudflare Account ID
# Find at: https://dash.cloudflare.com/ → Select Account → Account ID in sidebar
# Format: 32-character hexadecimal string
CLOUDFLARE_ACCOUNT_ID=00000000000000000000000000000000

# Your Cloudflare Zone ID for provii.app
# Find at: https://dash.cloudflare.com/ → Select Domain → Overview → Zone ID
# Format: 32-character hexadecimal string
CLOUDFLARE_ZONE_ID=00000000000000000000000000000000

# Cloudflare API Token (for admin tools)
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Account.Workers KV Storage (Edit)
# This is NOT stored in wrangler.toml, only used by admin tools
CF_API_TOKEN=REPLACE_ME_WITH_REAL_TOKEN

#######################################################################
# KV Namespace IDs - Sandbox Environment
#######################################################################
# These IDs point to SANDBOX_ISSUER_* namespaces
# Find namespace IDs: wrangler kv:namespace list
# Or at: https://dash.cloudflare.com/ → Workers & Pages → KV

# Session storage for active issuance sessions
KV_SESSIONS_ID=00000000000000000000000000000000

# Officer registry (YubiKey HMAC secret mappings)
KV_OFFICER_REGISTRY_ID=00000000000000000000000000000000

# Signing keypairs (RedJubjub keys)
KV_KEYS_ID=00000000000000000000000000000000

# Issuer configuration (metadata, policies)
KV_CONFIG_ID=00000000000000000000000000000000

# Audit log for security events
KV_AUDIT_LOG_ID=00000000000000000000000000000000

# Rate limiting counters
KV_RATE_LIMITS_ID=00000000000000000000000000000000

# Token bucket rate limiting
KV_TOKEN_BUCKETS_ID=00000000000000000000000000000000

# Registered API clients
KV_CLIENTS_ID=00000000000000000000000000000000

# One-time pickup tokens
KV_PICKUP_ID=00000000000000000000000000000000

# YubiKey authentication challenges
KV_CHALLENGES_ID=00000000000000000000000000000000

# Nonce tracking (prevent replay attacks)
KV_NONCES_ID=00000000000000000000000000000000

#######################################################################
# Production Environment Override
#######################################################################
# For production deployment, create a separate .env.production file
# or use environment-specific variables in your CI/CD pipeline.
#
# Production namespaces use PRODUCTION_ISSUER_* naming convention.
# NEVER use the same namespace IDs for sandbox and production!
#
# Example production deployment:
#   export KV_SESSIONS_ID=<production_sessions_id>
#   export KV_OFFICER_REGISTRY_ID=<production_officer_registry_id>
#   # ... set all other production KV IDs ...
#   wrangler deploy --env production

#######################################################################
# Admin Tool Configuration
#######################################################################
# These variables are used by tools in tools/

# For admin-officer tool (officer registry management)
# Set to the same value as KV_OFFICER_REGISTRY_ID above
KV_NAMESPACE_ID=00000000000000000000000000000000

#######################################################################
# Security Best Practices
#######################################################################
#
# 1. NEVER commit .env files to version control
# 2. Use different namespace IDs for sandbox/production
# 3. Rotate API tokens regularly
# 4. Restrict API token permissions to minimum required
# 5. Use separate Cloudflare accounts for production if possible
# 6. Store production secrets in secure secret management (e.g., 1Password, Vault)
# 7. Use CI/CD environment variables for automated deployments
# 8. Audit access to infrastructure IDs regularly
#
